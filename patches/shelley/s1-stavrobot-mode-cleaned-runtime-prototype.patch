+// IsStavrobotMode reports whether this conversation should dispatch through the Stavrobot path.
+func (cm *ConversationManager) IsStavrobotMode() bool {
+	cm.mu.Lock()
+	defer cm.mu.Unlock()
+	return cm.conversationOptions.IsStavrobot()
+}
+
+// StavrobotOptions returns a copy of the current Stavrobot options if present.
+func (cm *ConversationManager) StavrobotOptions() *db.StavrobotOptions {
+	cm.mu.Lock()
+	defer cm.mu.Unlock()
+	if cm.conversationOptions.Stavrobot == nil {
+		return nil
+	}
+	copy := *cm.conversationOptions.Stavrobot
+	return &copy
+}
