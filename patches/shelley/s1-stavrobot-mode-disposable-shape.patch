+func (s *Server) resolveStavrobotBridgeProfile(profileName string) (scriptPath string, args []string, err error) {
+	if profileName == "" {
+		return "", nil, fmt.Errorf("empty stavrobot bridge profile")
+	}
+
+	// Minimal disposable-spike contract:
+	// use the canonical bridge from the main repo and map the default profile to the local stack.
+	// A future real implementation should load installer-managed profile state instead.
+	const bridgePath = "/home/exedev/exe-stavrobot-shelley/shelley-stavrobot-bridge.sh"
+	if _, statErr := os.Stat(bridgePath); statErr != nil {
+		return "", nil, fmt.Errorf("canonical stavrobot bridge not found: %w", statErr)
+	}
+
+	switch profileName {
+	case "local-default":
+		return bridgePath, []string{
+			"--stateless",
+			"--pretty",
+			"--config-path", "/tmp/stavrobot/data/main/config.toml",
+			"--base-url", "http://localhost:8000",
+		}, nil
+	default:
+		return "", nil, fmt.Errorf("unknown stavrobot bridge profile: %s", profileName)
+	}
+}
+
+func (s *Server) runStavrobotTurn(ctx context.Context, opts *db.StavrobotOptions, userMessage llm.Message) (responseText, conversationID, messageID string, err error) {
+	if opts == nil {
+		return "", "", "", fmt.Errorf("missing stavrobot options")
+	}
+	if len(userMessage.Content) == 0 || userMessage.Content[0].Type != llm.ContentTypeText {
+		return "", "", "", fmt.Errorf("stavrobot mode currently requires plain text user messages")
+	}
+
+	scriptPath, baseArgs, err := s.resolveStavrobotBridgeProfile(opts.BridgeProfile)
+	if err != nil {
+		return "", "", "", err
+	}
+
+	args := append([]string{}, baseArgs...)
+	args = append(args, "chat", "--message", userMessage.Content[0].Text)
+	if opts.ConversationID != "" {
+		args = append(args, "--conversation-id", opts.ConversationID)
+	}
+
+	cmd := exec.CommandContext(ctx, scriptPath, args...)
+	output, err := cmd.Output()
+	if err != nil {
+		return "", "", "", fmt.Errorf("stavrobot bridge failed: %w", err)
+	}
+
+	var payload struct {
+		Response       string `json:"response"`
+		ConversationID string `json:"conversation_id"`
+		MessageID      string `json:"message_id"`
+	}
+	if err := json.Unmarshal(output, &payload); err != nil {
+		return "", "", "", fmt.Errorf("failed to parse stavrobot bridge output: %w", err)
+	}
+	return payload.Response, payload.ConversationID, payload.MessageID, nil
+}
+
+func (s *Server) handleStavrobotTurn(ctx context.Context, manager *ConversationManager, userMessage llm.Message) error {
+	if manager == nil {
+		return fmt.Errorf("nil conversation manager")
+	}
+	opts := manager.StavrobotOptions()
+	if opts == nil {
+		return fmt.Errorf("missing stavrobot conversation options")
+	}
+
+	manager.SetAgentWorking(true)
+	defer manager.SetAgentWorking(false)
+
+	if err := s.recordMessage(ctx, manager.conversationID, userMessage, llm.Usage{}); err != nil {
+		return fmt.Errorf("failed to record stavrobot user message: %w", err)
+	}
+
+	responseText, remoteConversationID, remoteMessageID, err := s.runStavrobotTurn(ctx, opts, userMessage)
+	if err != nil {
+		errMsg := llm.Message{
+			Role:      llm.MessageRoleAssistant,
+			Content:   []llm.Content{{Type: llm.ContentTypeText, Text: fmt.Sprintf("[Stavrobot error] %v", err)}},
+			EndOfTurn: true,
+			ErrorType: llm.ErrorTypeLLMRequest,
+		}
+		_ = s.recordMessage(context.WithoutCancel(ctx), manager.conversationID, errMsg, llm.Usage{})
+		return err
+	}
+
+	if remoteConversationID != "" || remoteMessageID != "" {
+		if err := manager.UpdateStavrobotMapping(context.WithoutCancel(ctx), remoteConversationID, remoteMessageID); err != nil {
+			s.logger.Warn("failed to persist stavrobot mapping", "conversationID", manager.conversationID, "error", err)
+		}
+	}
+
+	assistantMessage := llm.Message{
+		Role: llm.MessageRoleAssistant,
+		Content: []llm.Content{
+			{Type: llm.ContentTypeText, Text: responseText},
+		},
+		EndOfTurn: true,
+	}
+	userData := map[string]any{
+		"stavrobot": map[string]any{
+			"conversation_id": remoteConversationID,
+			"message_id":      remoteMessageID,
+			"bridge_profile":  opts.BridgeProfile,
+		},
+	}
+	if err := s.recordMessage(ctx, manager.conversationID, assistantMessage, llm.Usage{}, userData); err != nil {
+		return fmt.Errorf("failed to record stavrobot assistant message: %w", err)
+	}
+
+	go s.notifySubscribers(context.WithoutCancel(ctx), manager.conversationID)
+	return nil
+}
