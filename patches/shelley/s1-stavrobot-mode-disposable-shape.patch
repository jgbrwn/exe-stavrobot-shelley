+// UpdateStavrobotMapping updates the per-conversation stored Stavrobot mapping metadata.
+func (cm *ConversationManager) UpdateStavrobotMapping(ctx context.Context, conversationID, lastMessageID string) error {
+	cm.mu.Lock()
+	opts := cm.conversationOptions
+	if opts.Stavrobot == nil {
+		opts.Stavrobot = &db.StavrobotOptions{}
+	}
+	opts.Type = "stavrobot"
+	opts.Stavrobot.Enabled = true
+	if conversationID != "" {
+		opts.Stavrobot.ConversationID = conversationID
+	}
+	if lastMessageID != "" {
+		opts.Stavrobot.LastMessageID = lastMessageID
+	}
+	cm.mu.Unlock()
+
+	optsJSON, err := json.Marshal(opts)
+	if err != nil {
+		return fmt.Errorf("failed to marshal conversation options: %w", err)
+	}
+	jsonStr := string(optsJSON)
+
+	if err := cm.db.QueriesTx(ctx, func(q *generated.Queries) error {
+		_, err := q.UpdateConversationOptions(ctx, generated.UpdateConversationOptionsParams{
+			ConversationOptions: jsonStr,
+			ConversationID:      cm.conversationID,
+		})
+		return err
+	}); err != nil {
+		return fmt.Errorf("failed to persist stavrobot mapping: %w", err)
+	}
+
+	cm.mu.Lock()
+	cm.conversationOptions = opts
+	cm.mu.Unlock()
+	return nil
+}
