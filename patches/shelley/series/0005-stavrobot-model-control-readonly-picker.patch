+func (s *Server) executeStavrobotModelControl(ctx context.Context, profile *ResolvedStavrobotProfile, action string, args ...string) ([]byte, error) {
+	if profile == nil {
+		return nil, fmt.Errorf("missing stavrobot resolved profile")
+	}
+	if strings.TrimSpace(action) == "" {
+		return nil, fmt.Errorf("missing stavrobot model-control action")
+	}
+
+	helperPath := "/opt/stavrobot-installer/manage-stavrobot-model.sh"
+	if value := os.Getenv("SHELLEY_STAVROBOT_MODEL_CONTROL_HELPER_PATH"); strings.TrimSpace(value) != "" {
+		helperPath = value
+	}
+	if !filepath.IsAbs(helperPath) {
+		return nil, fmt.Errorf("stavrobot model-control helper path must be absolute: %s", helperPath)
+	}
+	if stat, err := os.Stat(helperPath); err != nil {
+		return nil, fmt.Errorf("stavrobot model-control helper missing: %w", err)
+	} else if stat.Mode()&0o111 == 0 {
+		return nil, fmt.Errorf("stavrobot model-control helper not executable: %s", helperPath)
+	}
+
+	cmdArgs := []string{action, "--config-path", profile.ConfigPath, "--base-url", profile.BaseURL}
+	cmdArgs = append(cmdArgs, args...)
+	cmd := exec.CommandContext(ctx, helperPath, cmdArgs...)
+	output, err := cmd.CombinedOutput()
+	if err != nil {
+		trimmed := strings.TrimSpace(string(output))
+		if trimmed == "" {
+			trimmed = err.Error()
+		}
+		return nil, fmt.Errorf("stavrobot model-control helper failed: %s", trimmed)
+	}
+	return output, nil
+}
+
+func (s *Server) GetStavrobotModelControlView(ctx context.Context, manager *ConversationManager) (*StavrobotModelControlCurrent, []StavrobotModelOption, error) {
+	if manager == nil {
+		return nil, nil, fmt.Errorf("nil conversation manager")
+	}
+	if !manager.IsStavrobotMode() {
+		return nil, nil, fmt.Errorf("stavrobot model control is only available in stavrobot mode")
+	}
+
+	opts := manager.StavrobotOptions()
+	if opts == nil {
+		return nil, nil, fmt.Errorf("missing stavrobot conversation options")
+	}
+	state, err := LoadStavrobotBridgeProfiles(s.stavrobotProfileStatePath())
+	if err != nil {
+		return nil, nil, err
+	}
+	profile, err := ResolveStavrobotBridgeProfile(state, opts.BridgeProfile)
+	if err != nil {
+		return nil, nil, err
+	}
+
+	currentOut, err := s.executeStavrobotModelControl(ctx, profile, "get-current")
+	if err != nil {
+		return nil, nil, err
+	}
+
+	var current StavrobotModelControlCurrent
+	if err := json.Unmarshal(currentOut, &current); err != nil {
+		return nil, nil, fmt.Errorf("invalid get-current response: %w", err)
+	}
+	if current.Status != "ok" {
+		return nil, nil, fmt.Errorf("unexpected get-current status: %s", current.Status)
+	}
+
+	if !current.OpenrouterModelSelectionAvailable {
+		return &current, []StavrobotModelOption{}, nil
+	}
+
+	listOut, err := s.executeStavrobotModelControl(ctx, profile, "list-openrouter-free")
+	if err != nil {
+		return nil, nil, err
+	}
+
+	var listResp StavrobotModelControlListResponse
+	if err := json.Unmarshal(listOut, &listResp); err != nil {
+		return nil, nil, fmt.Errorf("invalid list-openrouter-free response: %w", err)
+	}
+	if listResp.Status != "ok" {
+		if listResp.Message != "" {
+			return nil, nil, fmt.Errorf("list-openrouter-free failed: %s", listResp.Message)
+		}
+		if listResp.Error != "" {
+			return nil, nil, fmt.Errorf("list-openrouter-free failed: %s", listResp.Error)
+		}
+		return nil, nil, fmt.Errorf("list-openrouter-free failed with status: %s", listResp.Status)
+	}
+
+	return &current, listResp.Models, nil
+}
