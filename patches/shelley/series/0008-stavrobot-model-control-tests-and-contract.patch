+func TestHandleStavrobotModelControlApplySuccess(t *testing.T) {
+	h := NewTestHarness(t)
+	setupStavrobotModelControlRuntime(
+		t,
+		`{"status":"ok","provider":"openrouter","model":"openrouter/model-a","openrouter_model_selection_available":true}`,
+		`{"status":"ok","models":[]}`,
+		`{"status":"ok","operation":"set","previous_model":"openrouter/model-a","current_model":"openrouter/model-b","attempted_model":"openrouter/model-b","provider":"openrouter","ready":true}`,
+	)
+	conversationID := createConversationWithOptions(t, h, db.ConversationOptions{
+		Type: "stavrobot",
+		Stavrobot: &db.StavrobotOptions{
+			Enabled:       true,
+			BridgeProfile: "local-default",
+		},
+	})
+
+	req := httptest.NewRequest(http.MethodPost, "/api/conversation/"+conversationID+"/stavrobot/model-control-apply", bytes.NewBufferString(`{"model":"openrouter/model-b"}`))
+	req.Header.Set("Content-Type", "application/json")
+	w := httptest.NewRecorder()
+	h.server.handleStavrobotModelControlApply(w, req, conversationID)
+
+	if w.Code != http.StatusOK {
+		t.Fatalf("expected status %d, got %d: %s", http.StatusOK, w.Code, w.Body.String())
+	}
+
+	var resp struct {
+		Status string                    `json:"status"`
+		Apply  StavrobotModelApplyResult `json:"apply"`
+	}
+	if err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {
+		t.Fatalf("failed to decode response: %v", err)
+	}
+
+	if resp.Status != "ok" {
+		t.Fatalf("expected status=ok, got %q", resp.Status)
+	}
+	if resp.Apply.Operation != "set" {
+		t.Fatalf("expected operation=set, got %q", resp.Apply.Operation)
+	}
+	if resp.Apply.PreviousModel != "openrouter/model-a" || resp.Apply.CurrentModel != "openrouter/model-b" {
+		t.Fatalf("unexpected model transition: %#v", resp.Apply)
+	}
+	if !resp.Apply.Ready {
+		t.Fatalf("expected ready=true, got false")
+	}
+}
