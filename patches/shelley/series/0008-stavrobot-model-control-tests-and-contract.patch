+func writeExecutableFile(t *testing.T, path, content string) {
+	t.Helper()
+	if err := os.WriteFile(path, []byte(content), 0o755); err != nil {
+		t.Fatalf("failed to write executable %s: %v", path, err)
+	}
+}
+
+func setupStavrobotModelControlRuntime(t *testing.T, getCurrentJSON, listJSON, applyJSON string) {
+	t.Helper()
+	tmpDir := t.TempDir()
+
+	helperPath := filepath.Join(tmpDir, "manage-stavrobot-model.sh")
+	writeExecutableFile(t, helperPath, `#!/usr/bin/env bash
+set -euo pipefail
+script_dir="$(cd "$(dirname "$0")" && pwd)"
+action="${1:-}"
+case "$action" in
+  get-current)
+    cat "$script_dir/get-current.json"
+    ;;
+  list-openrouter-free)
+    cat "$script_dir/list-openrouter-free.json"
+    ;;
+  apply)
+    cat "$script_dir/apply.json"
+    ;;
+  *)
+    echo "unsupported action: $action" >&2
+    exit 1
+    ;;
+esac
+`)
+
+	if err := os.WriteFile(filepath.Join(tmpDir, "get-current.json"), []byte(getCurrentJSON), 0o644); err != nil {
+		t.Fatalf("failed to write get-current fixture: %v", err)
+	}
+	if err := os.WriteFile(filepath.Join(tmpDir, "list-openrouter-free.json"), []byte(listJSON), 0o644); err != nil {
+		t.Fatalf("failed to write list fixture: %v", err)
+	}
+	if err := os.WriteFile(filepath.Join(tmpDir, "apply.json"), []byte(applyJSON), 0o644); err != nil {
+		t.Fatalf("failed to write apply fixture: %v", err)
+	}
+
+	configPath := filepath.Join(tmpDir, "stavrobot-config.json")
+	if err := os.WriteFile(configPath, []byte("{}\n"), 0o644); err != nil {
+		t.Fatalf("failed to write config fixture: %v", err)
+	}
+
+	statePath := filepath.Join(tmpDir, "shelley-bridge-profiles.json")
+	stateJSON := fmt.Sprintf(`{
+  "schema_version": 1,
+  "bridge_contract_version": 1,
+  "default_profile": "local-default",
+  "profiles": {
+    "local-default": {
+      "enabled": true,
+      "bridge_path": "/bin/echo",
+      "base_url": "http://localhost:8000",
+      "config_path": %q,
+      "args": []
+    }
+  }
+}
+`, configPath)
+	if err := os.WriteFile(statePath, []byte(stateJSON), 0o644); err != nil {
+		t.Fatalf("failed to write bridge profile state fixture: %v", err)
+	}
+
+	t.Setenv("SHELLEY_STAVROBOT_PROFILE_STATE_PATH", statePath)
+	t.Setenv("SHELLEY_STAVROBOT_MODEL_CONTROL_HELPER_PATH", helperPath)
+}
+
+func createConversationWithOptions(t *testing.T, h *TestHarness, opts db.ConversationOptions) string {
+	t.Helper()
+	conv, err := h.db.CreateConversation(context.Background(), nil, true, nil, nil, opts)
+	if err != nil {
+		t.Fatalf("failed to create conversation: %v", err)
+	}
+	return conv.ConversationID
+}
+
+func TestHandleStavrobotModelControlViewRejectsNonStavrobotConversation(t *testing.T) {
+	h := NewTestHarness(t)
+	conversationID := createConversationWithOptions(t, h, db.ConversationOptions{})
+
+	req := httptest.NewRequest(http.MethodGet, "/api/conversation/"+conversationID+"/stavrobot/model-control-view", nil)
+	w := httptest.NewRecorder()
+	h.server.handleStavrobotModelControlView(w, req, conversationID)
+
+	if w.Code != http.StatusBadRequest {
+		t.Fatalf("expected status %d, got %d: %s", http.StatusBadRequest, w.Code, w.Body.String())
+	}
+	if !strings.Contains(w.Body.String(), "stavrobot model control is only available in stavrobot mode") {
+		t.Fatalf("expected non-stavrobot rejection message, got: %s", w.Body.String())
+	}
+}
+
+func TestHandleStavrobotModelControlViewGatedOpenRouterIncludesReason(t *testing.T) {
+	h := NewTestHarness(t)
+	setupStavrobotModelControlRuntime(
+		t,
+		`{"status":"ok","provider":"anthropic","model":"claude-3.7","openrouter_model_selection_available":false,"reason":"provider must be openrouter"}`,
+		`{"status":"ok","models":[]}`,
+		`{"status":"ok","operation":"noop","ready":true}`,
+	)
+	conversationID := createConversationWithOptions(t, h, db.ConversationOptions{
+		Type: "stavrobot",
+		Stavrobot: &db.StavrobotOptions{
+			Enabled:       true,
+			BridgeProfile: "local-default",
+		},
+	})
+
+	req := httptest.NewRequest(http.MethodGet, "/api/conversation/"+conversationID+"/stavrobot/model-control-view", nil)
+	w := httptest.NewRecorder()
+	h.server.handleStavrobotModelControlView(w, req, conversationID)
+
+	if w.Code != http.StatusOK {
+		t.Fatalf("expected status %d, got %d: %s", http.StatusOK, w.Code, w.Body.String())
+	}
+
+	var resp struct {
+		Status  string                       `json:"status"`
+		Current StavrobotModelControlCurrent `json:"current"`
+		Models  []StavrobotModelOption       `json:"models"`
+	}
+	if err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {
+		t.Fatalf("failed to decode response: %v", err)
+	}
+	if resp.Status != "ok" {
+		t.Fatalf("expected status=ok response, got %q", resp.Status)
+	}
+	if resp.Current.Reason != "provider must be openrouter" {
+		t.Fatalf("expected reason to round-trip, got %q", resp.Current.Reason)
+	}
+	if len(resp.Models) != 0 {
+		t.Fatalf("expected no model options when picker is gated, got %d", len(resp.Models))
+	}
+}
