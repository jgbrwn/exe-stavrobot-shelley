+func (s *Server) ApplyStavrobotModelSelection(ctx context.Context, manager *ConversationManager, model string) (*StavrobotModelApplyResult, error) {
+	profile, err := s.resolveStavrobotModelControlProfile(manager)
+	if err != nil {
+		return nil, err
+	}
+	model = strings.TrimSpace(model)
+	if model == "" {
+		return nil, fmt.Errorf("model is required")
+	}
+
+	applyOut, err := s.executeStavrobotModelControl(ctx, profile, "apply", "--model", model)
+	if err != nil {
+		return nil, err
+	}
+
+	var result StavrobotModelApplyResult
+	if err := json.Unmarshal(applyOut, &result); err != nil {
+		return nil, fmt.Errorf("invalid apply response: %w", err)
+	}
+	if result.Status != "ok" {
+		if result.Message != "" {
+			return nil, fmt.Errorf("apply failed: %s", result.Message)
+		}
+		if result.Error != "" {
+			return nil, fmt.Errorf("apply failed: %s", result.Error)
+		}
+		return nil, fmt.Errorf("apply failed with status: %s", result.Status)
+	}
+
+	return &result, nil
+}
