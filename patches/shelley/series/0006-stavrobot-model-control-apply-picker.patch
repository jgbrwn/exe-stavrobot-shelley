+func (s *Server) handleStavrobotModelControlApply(w http.ResponseWriter, r *http.Request, conversationID string) {
+	if r.Method != http.MethodPost {
+		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
+		return
+	}
+
+	var req stavrobotModelControlApplyRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		http.Error(w, "invalid request body", http.StatusBadRequest)
+		return
+	}
+
+	ctx := r.Context()
+	manager, err := s.loadConversationManagerForStavrobotModelControl(ctx, conversationID)
+	if err != nil {
+		if errors.Is(err, errStavrobotModelControlConversationNotFound) {
+			http.Error(w, "Conversation not found", http.StatusNotFound)
+			return
+		}
+		s.logger.Error("Failed to load conversation manager for stavrobot model control apply", "conversationID", conversationID, "error", err)
+		http.Error(w, "Internal server error", http.StatusInternalServerError)
+		return
+	}
+
+	result, err := s.ApplyStavrobotModelSelection(ctx, manager, req.Model)
+	if err != nil {
+		s.logger.Error("Failed to apply stavrobot model selection", "conversationID", conversationID, "model", req.Model, "error", err)
+		http.Error(w, err.Error(), http.StatusBadRequest)
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	json.NewEncoder(w).Encode(map[string]any{
+		"status": "ok",
+		"apply":  result,
+	})
+}
